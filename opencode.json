{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "october-bus": {
      "type": "remote",
      "url": "http://127.0.0.1:62321/mcp",
      "enabled": true,
      "headers": {
        "X-October-Canvas": "{env:OCTOBER_BUS_CANVAS}",
        "X-October-Node": "{env:OCTOBER_BUS_NODE}"
      }
    }
  }
}
